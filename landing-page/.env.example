# === Hevolve AI / Nunba — Environment Variables ===
# Copy this file to .env.local and fill in your values.
# Defaults work for local development with the Nunba Flask backend on port 5000.

# --- Core API (local Flask backend) ---
REACT_APP_API_BASE_URL=http://localhost:5000
# REACT_APP_SOCIAL_API_URL=http://localhost:5000/api/social
# REACT_APP_CHAT_API_URL=http://localhost:5000

# --- Cloud (Hevolve AI hosted — override for self-hosted deployments) ---
# REACT_APP_CLOUD_API_URL=https://azurekong.hertzai.com
# REACT_APP_MAILER_API_URL=https://mailer.hertzai.com
# REACT_APP_AZURE_API_URL=https://azurekong.hertzai.com
# REACT_APP_SMS_API_URL=https://sms.hertzai.com

# --- Encryption (required — generate with: node src/pages/generateKey.js) ---
REACT_APP_SECRET_KEY=change-me-to-a-random-string

# --- Payments (PhonePe — optional, only needed for subscription features) ---
# REACT_APP_PHONEPE_MERCHANT_ID=
# REACT_APP_PHONEPE_SALT_INDEX=1
# REACT_APP_PHONEPE_SALT_KEY=

# --- Monitoring (optional) ---
# REACT_APP_SENTRY_DSN=https://your-key@o123456.ingest.us.sentry.io/456789
# REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX
