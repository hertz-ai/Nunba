# Nunba Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required API Keys (get from respective services)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# =============================================================================
# Application Settings
# =============================================================================
NUNBA_ENV=development
NUNBA_LOCAL_PORT=5000
NUNBA_API_URL=https://hevolve.ai/api

# =============================================================================
# Feature Flags
# =============================================================================
NUNBA_CRASH_REPORTING=true
NUNBA_PERFORMANCE=true
NUNBA_ANALYTICS=true

# =============================================================================
# Security (generate a random 32-char string for production)
# =============================================================================
NUNBA_API_TOKEN=your-secure-api-token-here
SOCIAL_SECRET_KEY=your-social-secret-key-here

# =============================================================================
# Cloud Service URLs (optional - defaults to localhost for offline mode)
# =============================================================================
# HAYSTACK_URL=http://localhost:8000/haystack/
# GPT3_URL=http://localhost:5459/
# GPT4_URL=http://localhost:5459/gpt-4
# VICUNA_URL=http://localhost:6777/chat
# CROSSBAR_WS_URL=ws://localhost:8088/ws

# =============================================================================
# Database
# =============================================================================
HEVOLVE_DB_PATH=
HARTOS_BACKEND_URL=http://localhost:5000

# =============================================================================
# TTS Configuration
# =============================================================================
TTS_ENGINE=piper
TTS_VOICE=en_US-lessac-medium

# =============================================================================
# LLM Configuration
# =============================================================================
LLAMA_MODEL_PATH=
LLAMA_CONTEXT_SIZE=4096
LLAMA_GPU_LAYERS=0
